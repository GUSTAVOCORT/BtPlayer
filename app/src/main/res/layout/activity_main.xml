<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Fondo cargable -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="@string/app_name"/>
    <View
        android:id="@+id/bgDim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"/>

    <!-- ===== MODO REPRODUCTOR ===== -->
    <LinearLayout
        android:id="@+id/playerRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="14dp"
        android:weightSum="10">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="5.6"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/cover"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/app_name"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:gravity="center_vertical">

                    <TextView android:id="@+id/txtDevice"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/waiting" android:textColor="@color/textDim"
                        android:textSize="12sp" android:singleLine="true" android:ellipsize="end"/>
                    <TextView android:id="@+id/txtTitle"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/no_track" android:textColor="@color/text"
                        android:textSize="26sp" android:textStyle="bold" android:singleLine="true"
                        android:ellipsize="marquee" android:marqueeRepeatLimit="marquee_forever"
                        android:focusable="true" android:focusableInTouchMode="true"
                        android:layout_marginTop="6dp"/>
                    <TextView android:id="@+id/txtArtist"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/accent" android:textSize="17sp"
                        android:singleLine="true" android:ellipsize="end" android:layout_marginTop="2dp"/>
                    <TextView android:id="@+id/txtAlbum"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/textDim" android:textSize="14sp"
                        android:singleLine="true" android:ellipsize="end" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="10dp">
                <SeekBar android:id="@+id/seek"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="1000" android:progressTint="@color/accent" android:thumbTint="@color/accent"/>
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/txtPos"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:text="0:00" android:textColor="@color/textDim" android:textSize="13sp"/>
                    <TextView android:id="@+id/txtDur"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:text="0:00" android:textColor="@color/textDim" android:textSize="13sp" android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center" android:layout_marginTop="10dp">
                <Button android:id="@+id/btnPrev" android:layout_width="60dp" android:layout_height="60dp"
                    android:background="@drawable/btn_circle" android:text="⏮" android:textColor="@color/text" android:textSize="20sp"/>
                <Button android:id="@+id/btnPlay" android:layout_width="76dp" android:layout_height="76dp"
                    android:layout_marginStart="20dp" android:layout_marginEnd="20dp"
                    android:background="@drawable/btn_play" android:text="▶" android:textColor="#0A0A0C" android:textSize="26sp"/>
                <Button android:id="@+id/btnNext" android:layout_width="60dp" android:layout_height="60dp"
                    android:background="@drawable/btn_circle" android:text="⏭" android:textColor="@color/text" android:textSize="20sp"/>
                <Button android:id="@+id/btnEq" android:layout_width="wrap_content" android:layout_height="48dp"
                    android:layout_marginStart="20dp" android:background="@drawable/btn_circle"
                    android:paddingStart="14dp" android:paddingEnd="14dp" android:text="@string/eq"
                    android:textColor="@color/text" android:textSize="13sp"/>
                <Button android:id="@+id/btnSettings" android:layout_width="48dp" android:layout_height="48dp"
                    android:layout_marginStart="10dp" android:background="@drawable/btn_circle"
                    android:text="⚙" android:textColor="@color/text" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/eqPanel"
                android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                android:orientation="horizontal" android:gravity="center" android:visibility="gone"
                android:background="@drawable/panel_bg" android:layout_marginTop="10dp" android:padding="8dp"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="4.4"
            android:layout_marginStart="14dp" android:background="@drawable/panel_bg" android:padding="10dp">
            <com.carplayer.btplayer.VisualizerView android:id="@+id/visualizer"
                android:layout_width="match_parent" android:layout_height="match_parent"/>
            <!-- Reloj embebido: se muestra en modo "reloj + musica", se oculta con el ecualizador -->
            <com.carplayer.btplayer.NixieClock android:id="@+id/nixiePanel"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:visibility="gone"/>
        </FrameLayout>
    </LinearLayout>

    <!-- ===== MODO RELOJ NIXIE (overlay, oculto por defecto) ===== -->
    <LinearLayout android:id="@+id/clockRoot"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center" android:visibility="gone"
        android:clickable="true" android:focusable="true"
        android:padding="30dp">
        <com.carplayer.btplayer.NixieClock android:id="@+id/nixie"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
        <TextView android:id="@+id/clockTrack"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/textDim" android:textSize="16sp" android:layout_marginTop="8dp"
            android:singleLine="true" android:ellipsize="end"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Toca para volver al reproductor"
            android:textColor="#66FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Marco de neon tipo aviso luminoso, encima de todo, no intercepta toques -->
    <com.carplayer.btplayer.NeonFrame android:id="@+id/neonFrame"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:clickable="false" android:focusable="false"/>

    <!-- panel de diagnostico (overlay superior, opcional) -->
    <TextView android:id="@+id/debugPanel"
        android:layout_width="match_parent" android:layout_height="140dp"
        android:layout_gravity="bottom" android:background="#CC000000"
        android:textColor="#8AFF8A" android:textSize="9sp" android:typeface="monospace"
        android:padding="6dp" android:visibility="gone" android:scrollbars="vertical"/>
</FrameLayout>
