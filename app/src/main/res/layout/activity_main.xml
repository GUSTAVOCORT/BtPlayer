<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg"
    android:padding="14dp"
    android:weightSum="10">

    <!-- COLUMNA IZQUIERDA: reproductor -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="5.6"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/cover"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:background="@drawable/panel_bg"
                android:scaleType="centerCrop"
                android:contentDescription="@string/app_name"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtDevice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/waiting"
                    android:textColor="@color/textDim"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_track"
                    android:textColor="@color/text"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/txtArtist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/accent"
                    android:textSize="17sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/txtAlbum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/textDim"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Barra de progreso + tiempos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp">

            <SeekBar
                android:id="@+id/seek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtPos"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/textDim"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/txtDur"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/textDim"
                    android:textSize="13sp"
                    android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Controles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnPrev"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/btn_circle"
                android:text="⏮"
                android:textColor="@color/text"
                android:textSize="22sp"/>

            <Button
                android:id="@+id/btnPlay"
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/btn_play"
                android:text="▶"
                android:textColor="#0A0A0C"
                android:textSize="28sp"/>

            <Button
                android:id="@+id/btnNext"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/btn_circle"
                android:text="⏭"
                android:textColor="@color/text"
                android:textSize="22sp"/>

            <Button
                android:id="@+id/btnEq"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginStart="28dp"
                android:background="@drawable/btn_circle"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/eq"
                android:textColor="@color/text"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Panel de ecualizador (oculto por defecto) -->
        <LinearLayout
            android:id="@+id/eqPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:background="@drawable/panel_bg"
            android:layout_marginTop="12dp"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- COLUMNA DERECHA: visualizador -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="4.4"
        android:layout_marginStart="14dp"
        android:background="@drawable/panel_bg"
        android:padding="10dp">

        <com.carplayer.btplayer.VisualizerView
            android:id="@+id/visualizer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>
</LinearLayout>
